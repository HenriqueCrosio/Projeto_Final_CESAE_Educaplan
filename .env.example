# Copie este arquivo para .env.local e preencha os valores.
# .env.local é ignorado pelo git (nunca commite segredos).

NODE_ENV='development'

# ── Auth0 ───────────────────────────────────────────────
# AUTH0_SECRET: gere com `openssl rand -hex 32`
AUTH0_SECRET=
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

AUTH0_SCOPE='openid profile email'
AUTH0_DEBUG=true
AUTH0_ADMIN_ROLE_ID='admin'
AUTH0_TEACHER_ROLE_ID='teacher'
AUTH0_SUBSTITUTE_ROLE_ID='substitute'
AUTH0_STUDENT_ROLE_ID='student'

# ── Banco de dados (Postgres) ───────────────────────────
# DATABASE_URL: connection string da app (em Neon, use a pooled URL com ?sslmode=require&pgbouncer=true)
DATABASE_URL=
# DIRECT_URL: conexão direta (sem pooler) usada pelo Prisma Migrate. Em Neon, a URL sem "-pooler".
DIRECT_URL=

# ── Integrações opcionais ───────────────────────────────
OPTIMIZE_API_KEY=
OPENAI_API_KEY=
